---
import BaseLayout from '../layouts/BaseLayout.astro';

const videos = [
  {
    title: 'Demo Reel',
    embedUrl: 'https://www.youtube.com/embed/cODxyX-7pAE',
    platform: 'YouTube',
    description: 'General demo reel showcasing technical art and game design work.',
  },
  {
    title: 'The Spare',
    embedUrl: 'https://player.vimeo.com/video/42439088?title=0&byline=0&portrait=0',
    platform: 'Vimeo',
    description: 'Five-minute animated short produced with a group of 12.',
  },
  {
    title: 'Thrive Inspire Reel',
    embedUrl: 'https://player.vimeo.com/video/156515019?title=0&byline=0&portrait=0',
    platform: 'Vimeo',
    description: 'Promotional reel connected to the Thrive VR physical therapy project.',
  },
  {
    title: 'Generalist Reel 2012',
    embedUrl: 'https://player.vimeo.com/video/42337411?title=0&byline=0&portrait=0',
    platform: 'Vimeo',
    description: 'Older generalist reel included to preserve the work history from the original site.',
  },
  {
    title: 'Rigging Reel 2012',
    embedUrl: 'https://player.vimeo.com/video/42337346?title=0&byline=0&portrait=0',
    platform: 'Vimeo',
    description: 'Character rigging reel covering IK/FK systems, facial controls, and deformation work.',
  },
];
---

<BaseLayout
  title="Reel — Aaron Low"
  description="Demo reels showcasing Technical Art and Game Design work by Aaron Low."
>
  <div class="page-content">
    <div class="container">

      <div class="page-header">
        <h1 class="page-title">Reel</h1>
        <p class="page-subtitle">Video showcases of technical art, rigging, and game design work.</p>
      </div>

      {videos.length > 0 ? (
        <div class="reel-list">
          {videos.map(video => (
            <section class="reel-item">
              <div class="reel-meta">
                <h2 class="reel-title">{video.title}</h2>
                <span class="reel-platform">{video.platform}</span>
              </div>
              {video.description && <p class="reel-desc">{video.description}</p>}
              <div class="video-wrapper">
                <iframe
                  src={video.embedUrl}
                  allow="autoplay; fullscreen; picture-in-picture"
                  allowfullscreen
                  title={video.title}
                ></iframe>
              </div>
            </section>
          ))}
        </div>
      ) : (
        <section class="reel-empty">
          <h2 class="reel-title">Demo reel coming soon</h2>
          <p class="reel-desc">
            Video embeds will appear here once the YouTube or Vimeo video ID is added.
          </p>
          <div class="reel-actions">
            <a href="https://youtube.com/@hawaiian_spawn" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              YouTube
            </a>
            <a href="https://vimeo.com/user8051156" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
              Vimeo
            </a>
          </div>
        </section>
      )}

    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 56px;
  }

  .page-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .page-subtitle {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .reel-list {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .reel-meta {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
  }

  .reel-title {
    font-size: 1.2rem;
    font-weight: 600;
  }

  .reel-platform {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .reel-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 16px;
    max-width: 560px;
  }

  .reel-empty {
    padding: 48px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .reel-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
