---
import { existsSync } from 'node:fs';
import BaseLayout from '../layouts/BaseLayout.astro';

const resumePath = '/assets/resume.pdf';
const resumeExists = existsSync(new URL('../../public/assets/resume.pdf', import.meta.url));
---

<BaseLayout
  title="Resume — Aaron Low"
  description="Resume of Aaron Low, Technical Artist and Game Designer."
>
  <div class="page-content">
    <div class="container">

      <div class="page-header">
        <div class="header-row">
          <div>
            <h1 class="page-title">Resume</h1>
            <p class="page-subtitle">Technical Artist & Game Designer</p>
          </div>
          {resumeExists && (
            <a href={resumePath} download class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download PDF
            </a>
          )}
        </div>
      </div>

      {resumeExists ? (
        <>
          <div class="pdf-wrapper">
            <iframe
              src={resumePath}
              title="Aaron Low Resume"
              type="application/pdf"
            ></iframe>
          </div>

          <p class="pdf-fallback">
            Can't see the PDF?
            <a href={resumePath} target="_blank" rel="noopener noreferrer">Open in a new tab</a>
            or use the download button above.
          </p>
        </>
      ) : (
        <section class="resume-empty">
          <h2>Resume coming soon</h2>
          <p>
            For current availability and work samples, reach out through the contact page.
          </p>
          <a href="/contact" class="btn btn-primary">Contact Aaron</a>
        </section>
      )}

    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 28px;
  }

  .header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .page-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }

  .page-subtitle {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .pdf-fallback {
    margin-top: 16px;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }

  .resume-empty {
    padding: 48px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .resume-empty h2 {
    font-size: 1.2rem;
    margin-bottom: 8px;
  }

  .resume-empty p {
    color: var(--text-muted);
    margin-bottom: 20px;
    max-width: 520px;
  }
</style>
